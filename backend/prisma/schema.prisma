generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  trips Trip[]
}

enum BudgetCategory {
  FOOD
  TRANSPORT
  HOTEL
  ACTIVITIES
  OTHER
}

enum TripVisibility {
  PRIVATE
  PUBLIC
}

enum TripStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}
enum ActivityCategory {
  ADVENTURE
  CULTURE
  FOOD
  RELAXATION
  NIGHTLIFE
  SHOPPING
  NATURE
  OTHER
}

model Trip {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title       String
  description String?

  startDate DateTime
  endDate   DateTime

  budgetTotal Float
  currency    String

  visibility TripVisibility @default(PRIVATE)
  shareSlug  String?

  status   TripStatus @default(PLANNING)
  coverUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stops     Stop[]
  budgets   Budget[]
  checklist ChecklistItem[]
  notes     Note[]
  expenses  Expense[]
}

model Stop {
  id     String @id @default(uuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  order  Int
  cityId String

  city       City       @relation(fields: [cityId], references: [id])
  activities Activity[]
  notes      Note[]

  startDate DateTime
  endDate   DateTime
  title     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, order])
}

model City {
  id      String  @id @default(uuid())
  name    String
  country String?

  stops     Stop[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id     String @id @default(uuid())
  stopId String
  stop   Stop   @relation(fields: [stopId], references: [id])

  order        Int
  title        String
  description  String?
  startTime    String?
  durationMins Int?
  cost         Float?
  category ActivityCategory

  activityId String?
  activity   ActivityMeta? @relation(fields: [activityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityMeta {
  id        String   @id @default(uuid())
  // placeholder; allows include: { activity: true }
  createdAt DateTime @default(now())

  activity Activity[]
}

model Budget {
  id     String @id @default(uuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  category BudgetCategory
  planned  Float

  expenses Expense[]

  @@unique([tripId, category])
}

model ChecklistItem {
  id     String @id @default(uuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  category BudgetCategory
  label    String
  packed   Boolean        @default(false)
  order    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, order])
}

model Note {
  id     String @id @default(uuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  title  String
  body   String
  stopId String?
  stop   Stop?   @relation(fields: [stopId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id     String @id @default(uuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  category BudgetCategory
  amount   Float
  title    String?
  spentAt  DateTime
  notes    String?

  budgetId String?
  budget   Budget? @relation(fields: [budgetId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
