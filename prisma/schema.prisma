generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TripVisibility {
  PRIVATE
  PUBLIC
}

enum TripStatus {
  PLANNING
  UPCOMING
  ONGOING
  COMPLETED
}

enum ActivityCategory {
  SIGHTSEEING
  FOOD
  ADVENTURE
  SHOPPING
  CULTURE
}

enum BudgetCategory {
  TRANSPORT
  FOOD
  LODGING
  ACTIVITIES
  SHOPPING
  MISCELLANEOUS
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  avatarUrl     String?
  city          String?
  country       String?
  language      String         @default("en")
  preferences   Json           @default("[]")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  trips         Trip[]
  notes         Note[]
  expenses      Expense[]

  @@index([role])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Trip {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  title       String
  description String?
  coverUrl    String?
  startDate   DateTime
  endDate     DateTime
  visibility  TripVisibility @default(PRIVATE)
  status      TripStatus     @default(PLANNING)
  budgetTotal Decimal        @default(0) @db.Decimal(12, 2)
  currency    String         @default("USD")
  shareSlug   String?        @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops       Stop[]
  budgets     Budget[]
  checklist   ChecklistItem[]
  notes       Note[]
  expenses    Expense[]

  @@index([userId, status])
  @@index([visibility])
  @@index([shareSlug])
  @@index([startDate, endDate])
}

model Stop {
  id          String         @id @default(uuid()) @db.Uuid
  tripId      String         @db.Uuid
  cityId      String?        @db.Uuid
  title       String
  order       Int
  startDate   DateTime
  endDate     DateTime
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city        City?          @relation(fields: [cityId], references: [id], onDelete: SetNull)
  activities  StopActivity[]
  linkedNotes Note[]

  @@unique([tripId, order])
  @@index([tripId])
  @@index([cityId])
}

model City {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  country     String
  region      String
  costIndex   Int
  popularity  Int
  imageUrl    String
  description String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
  stops       Stop[]

  @@unique([name, country])
  @@index([region])
  @@index([popularity])
  @@index([costIndex])
}

model Activity {
  id           String           @id @default(uuid()) @db.Uuid
  cityId       String           @db.Uuid
  title        String
  category     ActivityCategory
  description  String
  durationMins Int
  estimatedCost Decimal         @default(0) @db.Decimal(10, 2)
  imageUrl     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  city         City             @relation(fields: [cityId], references: [id], onDelete: Cascade)
  stopLinks    StopActivity[]

  @@index([cityId, category])
  @@index([estimatedCost])
}

model StopActivity {
  id           String    @id @default(uuid()) @db.Uuid
  stopId       String    @db.Uuid
  activityId   String?   @db.Uuid
  title        String
  description  String?
  startTime    DateTime?
  durationMins Int       @default(60)
  cost         Decimal   @default(0) @db.Decimal(10, 2)
  order        Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  stop         Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)
  activity     Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@unique([stopId, order])
  @@index([stopId])
  @@index([activityId])
}

model Budget {
  id        String         @id @default(uuid()) @db.Uuid
  tripId    String         @db.Uuid
  category  BudgetCategory
  planned   Decimal        @default(0) @db.Decimal(12, 2)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, category])
  @@index([tripId])
}

model Expense {
  id        String         @id @default(uuid()) @db.Uuid
  tripId    String         @db.Uuid
  userId    String         @db.Uuid
  category  BudgetCategory
  title     String
  amount    Decimal        @db.Decimal(12, 2)
  spentAt   DateTime
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId, category])
  @@index([userId])
  @@index([spentAt])
}

model ChecklistItem {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @db.Uuid
  category  String
  label     String
  packed    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, category])
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @db.Uuid
  userId    String   @db.Uuid
  stopId    String?  @db.Uuid
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stop      Stop?    @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([userId])
  @@index([stopId])
}
